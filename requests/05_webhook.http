# ─────────────────────────────────────────────────────────────
# Webhook Simulation — Simulasi Notifikasi dari Provider
#
# Endpoint ini dipanggil provider saat status payment/disbursement berubah.
# Untuk dev/test, simulasikan request yang biasanya datang dari provider.
#
# PENTING:
#   - Isi externalId dengan nilai "external_id" dari response payment
#   - Signature harus valid — lihat catatan per provider di bawah
#   - Webhook route tidak memerlukan X-API-Key
#   - Route: POST /webhooks/{provider}/payment
#            POST /webhooks/{provider}/disbursement
#
# Provider valid: midtrans, xendit, doku, ipaymu
# ─────────────────────────────────────────────────────────────

@baseUrl    = http://localhost:8080

# Isi dengan external_id dari response payment (bukan payment.id)
@externalId = wpay-1234567890-abcdef12


# ══════════════════════════════════════════════════════════════
# MIDTRANS
# Signature: SHA512(order_id + status_code + gross_amount + server_key)
# Contoh generate: echo -n "wpay-xxx200100000.00<server_key>" | sha512sum
# server_key → .config.toml [provider.midtrans] server_key
# ══════════════════════════════════════════════════════════════

### Midtrans — VA settlement (pembayaran berhasil)
POST {{baseUrl}}/webhooks/midtrans/payment
Content-Type: application/json

{
  "order_id": "{{externalId}}",
  "transaction_id": "midtrans-txn-123456",
  "status_code": "200",
  "gross_amount": "100000.00",
  "payment_type": "bank_transfer",
  "transaction_status": "settlement",
  "fraud_status": "accept",
  "signature_key": "GANTI_DENGAN_SHA512_VALID",
  "transaction_time": "2026-06-28 10:30:00",
  "settlement_time": "2026-06-28 10:31:00",
  "va_numbers": [
    {
      "bank": "bca",
      "va_number": "1234560000099999"
    }
  ]
}


### Midtrans — QRIS settlement
POST {{baseUrl}}/webhooks/midtrans/payment
Content-Type: application/json

{
  "order_id": "{{externalId}}",
  "transaction_id": "midtrans-txn-qris-001",
  "status_code": "200",
  "gross_amount": "50000.00",
  "payment_type": "qris",
  "transaction_status": "settlement",
  "fraud_status": "accept",
  "signature_key": "GANTI_DENGAN_SHA512_VALID",
  "transaction_time": "2026-06-28 11:00:00",
  "settlement_time": "2026-06-28 11:00:05"
}


### Midtrans — VA expire (tidak dibayar sampai expired)
POST {{baseUrl}}/webhooks/midtrans/payment
Content-Type: application/json

{
  "order_id": "{{externalId}}",
  "transaction_id": "midtrans-txn-expired",
  "status_code": "407",
  "gross_amount": "100000.00",
  "payment_type": "bank_transfer",
  "transaction_status": "expire",
  "signature_key": "GANTI_DENGAN_SHA512_VALID",
  "transaction_time": "2026-06-28 10:30:00"
}


# ══════════════════════════════════════════════════════════════
# XENDIT
# Auth: x-callback-token header (static token, tidak pakai HMAC)
# Token → .config.toml [provider.xendit] webhook_token
# ══════════════════════════════════════════════════════════════

### Xendit — Payment SUCCEEDED
POST {{baseUrl}}/webhooks/xendit/payment
Content-Type: application/json
x-callback-token: GANTI_DENGAN_XENDIT_WEBHOOK_TOKEN

{
  "id": "pr-xendit-123456",
  "reference_id": "{{externalId}}",
  "status": "SUCCEEDED",
  "currency": "IDR",
  "amount": 200000,
  "payment_method": {
    "type": "VIRTUAL_ACCOUNT",
    "virtual_account": {
      "channel_code": "BNI",
      "channel_properties": {
        "virtual_account_number": "9876540000123456"
      }
    }
  },
  "created": "2026-06-28T10:00:00Z",
  "updated": "2026-06-28T10:05:00Z"
}


### Xendit — Payment FAILED
POST {{baseUrl}}/webhooks/xendit/payment
Content-Type: application/json
x-callback-token: GANTI_DENGAN_XENDIT_WEBHOOK_TOKEN

{
  "id": "pr-xendit-failed-001",
  "reference_id": "{{externalId}}",
  "status": "FAILED",
  "currency": "IDR",
  "amount": 200000,
  "failure_code": "PAYMENT_CANCELLED",
  "created": "2026-06-28T10:00:00Z",
  "updated": "2026-06-28T10:05:00Z"
}


### Xendit — Disbursement SUCCEEDED
POST {{baseUrl}}/webhooks/xendit/disbursement
Content-Type: application/json
x-callback-token: GANTI_DENGAN_XENDIT_WEBHOOK_TOKEN

{
  "id": "disb-xendit-001",
  "reference_id": "{{externalId}}",
  "status": "SUCCEEDED",
  "amount": 500000,
  "currency": "IDR",
  "channel_code": "BCA",
  "account_number": "1234567890",
  "account_holder_name": "Budi Santoso",
  "created": "2026-06-28T14:00:00Z",
  "updated": "2026-06-28T14:01:00Z"
}


### Xendit — Disbursement FAILED
POST {{baseUrl}}/webhooks/xendit/disbursement
Content-Type: application/json
x-callback-token: GANTI_DENGAN_XENDIT_WEBHOOK_TOKEN

{
  "id": "disb-xendit-failed-001",
  "reference_id": "{{externalId}}",
  "status": "FAILED",
  "amount": 500000,
  "currency": "IDR",
  "failure_code": "INVALID_ACCOUNT_NUMBER",
  "created": "2026-06-28T14:00:00Z",
  "updated": "2026-06-28T14:01:00Z"
}


# ══════════════════════════════════════════════════════════════
# IPAYMU
# Auth: x-wt header (static token)
# Token → .config.toml [provider.ipaymu] webhook_secret
# ══════════════════════════════════════════════════════════════

### iPaymu — Payment berhasil
POST {{baseUrl}}/webhooks/ipaymu/payment?wt=GANTI_DENGAN_IPAYMU_WEBHOOK_TOKEN
Content-Type: application/json

{
  "trx_id": "12345678",
  "reference_id": "{{externalId}}",
  "status": "berhasil",
  "via": "qris",
  "channel": "qris",
  "price": "50000",
  "buyer_name": "Dewi Lestari",
  "buyer_email": "dewi@example.com",
  "notes": "Pembelian produk digital"
}


### iPaymu — Payment expired
POST {{baseUrl}}/webhooks/ipaymu/payment?wt=GANTI_DENGAN_IPAYMU_WEBHOOK_TOKEN
Content-Type: application/json

{
  "trx_id": "12345679",
  "reference_id": "{{externalId}}",
  "status": "expired",
  "via": "va",
  "channel": "bni",
  "price": "75000"
}


# ══════════════════════════════════════════════════════════════
# DOKU
# Signature: HMAC-SHA512 hex (diverifikasi oleh adapter DOKU)
# Lihat DOKU SNAP documentation untuk cara generate signature
# ══════════════════════════════════════════════════════════════

### DOKU — VA payment success
POST {{baseUrl}}/webhooks/doku/payment
Content-Type: application/json
Client-Id: GANTI_DENGAN_DOKU_CLIENT_ID
Request-Id: req-doku-001
Request-Timestamp: 2026-06-28T10:30:00Z
Signature: HMAC-SHA512:GANTI_DENGAN_SIGNATURE_VALID

{
  "order": {
    "invoice_number": "{{externalId}}",
    "amount": 150000
  },
  "virtual_account_info": {
    "virtual_account_number": "89989009876543210",
    "bank_code": "BCA"
  },
  "service": {
    "id": "VA"
  },
  "acquirer": {
    "id": "BCA_VA"
  }
}
